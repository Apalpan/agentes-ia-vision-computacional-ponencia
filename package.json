{
  "name": "agentes-ia-vision-computacional-ponencia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Ponencia GEN+ sobre agentes IA y visión computacional aplicada a construcción.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "studio": "remotion studio src/remotion/index.ts",
    "render:deck": "remotion render src/remotion/index.ts KeynoteFull outputs/keynote-full.mp4",
    "render:opening": "remotion render src/remotion/index.ts OpeningClip outputs/clips/opening.mp4",
    "render:vision": "remotion render src/remotion/index.ts VisionToEventClip outputs/clips/vision-to-event.mp4",
    "render:edge": "remotion render src/remotion/index.ts EdgeLocalProtocolClip outputs/clips/edge-local.mp4",
    "render:voice": "remotion render src/remotion/index.ts VoiceProtocolClip outputs/clips/voice-protocol.mp4",
    "render:brain": "remotion render src/remotion/index.ts GPlusBrainClip outputs/clips/gplus-brain.mp4",
    "render:loop": "remotion render src/remotion/index.ts AgentLoopClip outputs/clips/agent-loop.mp4",
    "render:multiagent": "remotion render src/remotion/index.ts MultiAgentProtocolClip outputs/clips/multi-agent.mp4",
    "render:governance": "remotion render src/remotion/index.ts HumanGateProtocolClip outputs/clips/human-gate.mp4",
    "render:pilot": "remotion render src/remotion/index.ts PilotProtocolClip outputs/clips/pilot-protocol.mp4",
    "render:closing": "remotion render src/remotion/index.ts ClosingClip outputs/clips/closing.mp4",
    "render:clips": "node scripts/render-media.mjs",
    "qa:temporal": "node scripts/qa-temporal.mjs",
    "verify": "node scripts/verify.mjs",
    "qa": "node scripts/qa.mjs",
    "check": "npm run typecheck && npm run build && npm run verify && npm run qa"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.1.1",
    "@fontsource-variable/space-grotesk": "^5.1.1",
    "@remotion/cli": "^4.0.490",
    "@remotion/transitions": "^4.0.490",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.490"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "playwright-core": "^1.49.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
